{
  "name": "frontend",
  "displayName": "Frontend",
  "version": "0.5.0",
  "description": "Web frontend development toolkit — shadcn/ui, Next.js DevTools, React best practices, Supabase, DESIGN.md design system spec, and impeccable design skills",
  "keywords": [
    "frontend",
    "shadcn",
    "nextjs",
    "react",
    "supabase",
    "design",
    "ui",
    "tailwind",
    "impeccable",
    "anti-patterns",
    "design-tokens",
    "design.md",
    "design-vocabulary"
  ],
  "author": {
    "name": "Frad LEE",
    "email": "fradser@gmail.com"
  },
  "license": "MIT",
  "commands": [
    "./skills/impeccable/",
    "./skills/design-md/"
  ],
  "skills": [
    "./skills/shadcn/",
    "./skills/next-devtools-guide/",
    "./skills/react-best-practices/",
    "./skills/web-design-guidelines/",
    "./skills/articulate/",
    "./skills/supabase/",
    "./skills/supabase-postgres-best-practices/"
  ],
  "agents": [
    "./agents/frontend-expert.md",
    "./agents/frontend-anti-patterns.md"
  ],
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/design-md-first.sh"
          }
        ]
      }
    ]
  },
  "mcpServers": {
    "next-devtools": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "next-devtools-mcp@latest"
      ]
    }
  }
}
