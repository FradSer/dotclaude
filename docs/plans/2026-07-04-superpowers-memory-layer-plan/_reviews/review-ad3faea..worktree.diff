+  done
+  make_index "${rows[@]}"
+  _run bash "$DOCS_INDEX_SH" rebuild
+  if [[ "$LAST_EXIT" -eq 0 ]]; then
+    TESTS_PASSED=$((TESTS_PASSED + 1))
+  else
+    TESTS_FAILED=$((TESTS_FAILED + 1))
+    echo "FAIL: rebuild expected exit 0, got $LAST_EXIT" >&2
