{
  "name": "superpowers",
  "version": "2.1.0",
  "description": "Advanced development superpowers for orchestrating complex workflows with Superpower Loop and work verification",
  "author": {
    "name": "Frad LEE",
    "email": "fradser@gmail.com"
  },
  "license": "MIT",
  "keywords": [
    "planning",
    "brainstorming",
    "bdd",
    "teams",
    "execution",
    "verification"
  ],
  "commands": [
    "./skills/brainstorming/",
    "./skills/writing-plans/",
    "./skills/executing-plans/",
    "./skills/need-vet/"
  ],
  "skills": [
    "./skills/agent-team-driven-development/",
    "./skills/behavior-driven-development/",
    "./skills/build-like-iphone-team/",
    "./skills/systematic-debugging/"
  ],
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/task-start.sh",
            "statusMessage": "Setting completion criteria..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/track-changes.sh",
            "async": true
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/stop-hook.sh"
          }
        ]
      }
    ]
  }
}
