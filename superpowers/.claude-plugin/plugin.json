{
  "name": "superpowers",
  "displayName": "Superpowers",
  "version": "3.3.0",
  "description": "Advanced development workflow orchestration with BDD support and self-improving skills",
  "author": {
    "name": "Frad LEE",
    "email": "fradser@gmail.com"
  },
  "license": "MIT",
  "keywords": [
    "planning",
    "brainstorming",
    "bdd",
    "teams",
    "execution",
    "claude-code>=2.1.139"
  ],
  "agents": [
    "./agents/superpowers-evaluator.md"
  ],
  "commands": [
    "./skills/brainstorming/",
    "./skills/writing-plans/",
    "./skills/executing-plans/",
    "./skills/retrospective/",
    "./skills/systematic-debugging/"
  ],
  "skills": [
    "./skills/behavior-driven-development/",
    "./skills/using-superpowers/"
  ],
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/stop-state-sync.sh"
          }
        ]
