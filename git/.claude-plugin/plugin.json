{
  "name": "git",
  "displayName": "Git",
  "version": "0.5.3",
  "description": "Conventional Git automation and advanced repository management",
  "author": {
    "name": "Frad LEE",
    "email": "fradser@gmail.com"
  },
  "license": "MIT",
  "keywords": [
    "git",
    "conventional-commits",
    "automation",
    "workflow",
    "version-control"
  ],
  "commands": [
    "./skills/commit/",
    "./skills/commit-and-push/",
    "./skills/setup/"
  ],
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/validate-commit-pretool.sh"
          }
        ]
      }
    ]
  }
}
