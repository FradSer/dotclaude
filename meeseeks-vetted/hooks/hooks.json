{
  "description": "meeseeks-vetted hooks for task tracking and work verification",
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/task-start.sh",
            "statusMessage": "Setting completion criteria..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/verify-work.sh",
            "statusMessage": "Verifying work..."
          }
        ]
      }
    ]
  }
}
